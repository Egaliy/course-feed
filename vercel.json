{
  "version": 2,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/feed",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/a/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/feed",
      "destination": "/api"
    },
    {
      "source": "/a/:token",
      "destination": "/api?token=:token"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ]
}
